# Cartographic Engine — variables publiques (préfixe EXPO_PUBLIC_ = inliné dans le bundle)
# Token PUBLIC Mapbox (pk.…) — à restreindre par domaine/scopes dans le dashboard Mapbox.
# Laisser vide = la carte retombe automatiquement sur le placeholder (aucun crash).
EXPO_PUBLIC_MAPBOX_TOKEN=
# Optionnel : style Mapbox (défaut: mapbox://styles/mapbox/streets-v12)
EXPO_PUBLIC_MAPBOX_STYLE_URL=

# ⚠️ NE JAMAIS mettre ici (ni dans le repo) le token SECRET de téléchargement (sk.…).
#    Il sert uniquement au build natif (CocoaPods/Gradle) via ~/.netrc ou un secret EAS.
